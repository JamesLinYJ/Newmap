            "type": "string",
            "title": "产品标签",
            "x-source": "text"
          },
          "product_unit": {
            "type": "string",
            "title": "产品单位",
            "x-source": "text"
          },
          "min_display": {
            "type": "number",
            "title": "最小对比显示值",
            "x-source": "number"
          }
