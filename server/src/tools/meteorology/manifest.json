      "tags": [
        "meteorology"
      ],
      "isReadOnly": true,
      "isDestructive": false,
      "jsonSchema": {
        "type": "object",
        "properties": {
          "radar_collection_ref": {
            "type": "string",
            "title": "雷达文件集合引用",
            "description": "必须使用当前 run 中已存在的 valueRef ID",
            "x-source": "value_ref",
            "x-value-ref-kinds": [
              "radar_file_collection"
            ]
          }
        },
        "required": [
          "radar_collection_ref"
        ],
        "x-mini-app": {
          "type": "radar_mosaic_console"
        }
      }
    },
    {
      "name": "recommend_radar_mosaic_strategy",
