      "isDestructive": false,
      "jsonSchema": {
        "type": "object",
        "properties": {
          "goal_mode": {
            "type": "string",
            "title": "业务目标",
            "enum": [
              "quicklook",
              "quality",
              "smooth"
            ],
            "x-source": "text"
          },
          "time_strategy": {
            "type": "string",
            "title": "时间策略",
