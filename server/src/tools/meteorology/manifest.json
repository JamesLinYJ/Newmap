    {
      "name": "define_rainfall_risk_thresholds",
      "label": "定义短时强降水风险阈值",
      "description": "保存短时强降水风险区划图使用的阈值和调色板",
      "group": "气象",
      "tags": [
        "meteorology"
      ],
      "isReadOnly": true,
      "isDestructive": false,
      "jsonSchema": {
        "type": "object",
        "properties": {
          "thresholds": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "label",
                "min",
                "max",
                "color"
              ],
              "properties": {
                "label": {
                  "type": "string",
                  "minLength": 1
                },
                "min": {
                  "type": "number"
                },
                "max": {
                  "type": "number"
                },
                "color": {
                  "type": "string",
                  "pattern": "^#[0-9a-fA-F]{6}$"
                }
              }
            },
            "title": "阈值调色板 JSON",
            "x-source": "json",
            "default": [
              {
                "label": "无雨/小雨",
                "min": 0,
                "max": 1.5,
                "color": "#f0f0f0"
              },
              {
                "label": "短时大雨",
                "min": 1.5,
                "max": 3,
                "color": "#a6d96a"
              },
              {
                "label": "短时暴雨",
                "min": 3,
                "max": 5,
                "color": "#1a9850"
              },
              {
                "label": "短时大暴雨",
                "min": 5,
                "max": 8,
                "color": "#fdae61"
              },
              {
                "label": "短时大暴雨~特大暴雨",
                "min": 8,
                "max": 12,
                "color": "#d73027"
              },
              {
                "label": "短时特大暴雨",
                "min": 12,
                "max": 999,
                "color": "#7a0177"
              }
            ]
          }
        },
        "required": [],
        "x-mini-app": {
          "type": "rainfall_risk_map_console"
        }
      }
    },
