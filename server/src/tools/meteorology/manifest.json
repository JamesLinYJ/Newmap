  "name": "气象分析",
  "version": "0.1.0",
  "author": "geo-agent-platform",
  "language": "typescript",
  "description": "气象数据、短时临近预报（短临）降水与第三方气象制图工具",
  "requires": {
    "WORKER_URL": "required"
  },
  "tools": [
    {
      "name": "list_meteorological_files",
      "label": "列出气象文件",
      "description": "列出当前线程可用的通用气象文件",
      "group": "气象",
      "tags": [
        "meteorology"
      ],
      "isReadOnly": true,
      "isDestructive": false,
      "jsonSchema": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "name": "inspect_radar_station_collection",
      "label": "检查雷达站文件集",
      "description": "检查雷达 bz2 文件的站点和候选时次",
