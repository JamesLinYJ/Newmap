APP_NAME=geo-agent-platform
APP_ENV=development
API_HOST=127.0.0.1
API_PORT=8000
WEB_DEV_HOST=127.0.0.1
WEB_DEV_PORT=5173
APP_BASE_URL=http://127.0.0.1:8000
WEB_BASE_URL=http://127.0.0.1:5173
VITE_API_BASE_URL=
API_PROXY_TARGET=http://127.0.0.1:8000
POSTGIS_PORT=55432
RUNTIME_ROOT=./runtime
DATABASE_URL=postgresql://geo_agent:geo_agent@127.0.0.1:55432/geo_agent

BETTER_AUTH_URL=http://127.0.0.1:8000
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
BETTER_AUTH_ALLOW_SIGN_UP=true
BETTER_AUTH_REQUIRE_EMAIL_VERIFICATION=false
BETTER_AUTH_MIN_PASSWORD_LENGTH=12
CSRF_HEADER_NAME=x-geoforge-csrf
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
TRUSTED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

WORKER_URL=http://127.0.0.1:8012
WORKER_SHARED_SECRET=replace-with-at-least-32-random-characters
ENABLED_TOOL_PROVIDERS=geo-platform-chart,geo-platform-geocode,geo-platform-plan,geo-platform-developer-tools,geo-platform-spatial,geo-platform-meteorology,geo-platform-memory,geo-platform-media
DEVELOPER_TOOL_ALLOWED_ROOTS=C:\Projects\GeoForge
SEED_LAYERS_DIR=./infra/seeds/layers

DEFAULT_MODEL_PROVIDER=openai_compatible
DEFAULT_MODEL_NAME=
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=
GEMINI_BASE_URL=
GEMINI_API_KEY=
GEMINI_MODEL=

AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastasia
AZURE_SPEECH_ENDPOINT=https://eastasia.api.cognitive.microsoft.com
AZURE_SPEECH_DEFAULT_LANGUAGE=zh-CN
AZURE_SPEECH_SUPPORTED_LANGUAGES=zh-CN,en-US,ja-JP,ko-KR
AZURE_SPEECH_DEFAULT_VOICE=zh-CN-XiaoxiaoNeural
